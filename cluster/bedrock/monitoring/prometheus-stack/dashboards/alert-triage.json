{
  "title": "Alert Triage",
  "uid": "alert-triage-colfax",
  "tags": ["alerts", "triage"],
  "editable": true,
  "schemaVersion": 38,
  "refresh": "1m",
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "liveNow": false,
  "annotations": { "list": [] },
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Critical Firing",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }] },
          "mappings": [{ "type": "value", "options": { "0": { "text": "None", "color": "green", "index": 0 } } }],
          "noValue": "0",
          "unit": "short"
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none", "justifyMode": "center" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "count(ALERTS{alertstate=\"firing\", severity=\"critical\"}) or vector(0)", "legendFormat": "Critical", "refId": "A" }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Warning Firing",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }] },
          "mappings": [{ "type": "value", "options": { "0": { "text": "None", "color": "green", "index": 0 } } }],
          "noValue": "0",
          "unit": "short"
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none", "justifyMode": "center" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "count(ALERTS{alertstate=\"firing\", severity=\"warning\"}) or vector(0)", "legendFormat": "Warning", "refId": "A" }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total Firing",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 5 }] },
          "noValue": "0",
          "unit": "short"
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none", "justifyMode": "center" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "count(ALERTS{alertstate=\"firing\"}) or vector(0)", "legendFormat": "Total", "refId": "A" }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Longest Firing",
      "description": "Duration of the oldest firing alert",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 3600 }, { "color": "red", "value": 86400 }] },
          "noValue": "—",
          "unit": "s",
          "decimals": 0
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none", "justifyMode": "center" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max(time() - ALERTS_FOR_STATE{alertstate=\"firing\"}) or vector(0)", "legendFormat": "Longest", "refId": "A" }]
    },
    {
      "id": 5,
      "type": "table",
      "title": "Firing Alerts — sorted by severity, then longest firing first",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "left", "cellOptions": { "type": "auto" }, "inspect": false },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "severity" },
            "properties": [
              { "id": "custom.width", "value": 100 },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } },
              { "id": "mappings", "value": [
                { "type": "value", "options": { "critical": { "text": "critical", "color": "red", "index": 0 } } },
                { "type": "value", "options": { "warning": { "text": "warning", "color": "orange", "index": 1 } } },
                { "type": "value", "options": { "info": { "text": "info", "color": "blue", "index": 2 } } }
              ]}
            ]
          },
          { "matcher": { "id": "byName", "options": "firing_for" }, "properties": [{ "id": "unit", "value": "s" }, { "id": "custom.width", "value": 130 }, { "id": "displayName", "value": "Firing For" }] },
          { "matcher": { "id": "byName", "options": "alertname" }, "properties": [{ "id": "custom.width", "value": 280 }, { "id": "links", "value": [{ "title": "View in Grafana Alerts", "url": "/alerting/list" }] }] },
          { "matcher": { "id": "byName", "options": "namespace" }, "properties": [{ "id": "custom.width", "value": 160 }] },
          { "matcher": { "id": "byName", "options": "job" }, "properties": [{ "id": "custom.width", "value": 240 }] },
          { "matcher": { "id": "byName", "options": "Time" }, "properties": [{ "id": "custom.hidden", "value": true }] },
          { "matcher": { "id": "byName", "options": "Value #A" }, "properties": [{ "id": "custom.hidden", "value": true }] },
          { "matcher": { "id": "byName", "options": "Value #B" }, "properties": [{ "id": "custom.hidden", "value": true }] },
          { "matcher": { "id": "byName", "options": "alertstate" }, "properties": [{ "id": "custom.hidden", "value": true }] },
          { "matcher": { "id": "byName", "options": "__name__" }, "properties": [{ "id": "custom.hidden", "value": true }] }
        ]
      },
      "options": {
        "footer": { "show": false },
        "frameIndex": 0,
        "showHeader": true,
        "sortBy": [{ "desc": false, "displayName": "severity" }, { "desc": true, "displayName": "Firing For" }]
      },
      "transformations": [
        { "id": "merge", "options": {} },
        { "id": "labelsToFields", "options": { "mode": "columns" } },
        {
          "id": "calculateField",
          "options": {
            "alias": "firing_for",
            "mode": "reduceRow",
            "reduce": { "reducer": "sum" },
            "binary": { "left": "Value #B", "reducer": "sum", "right": "Value #B" }
          }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": { "Value #B": "firing_for" }
          }
        }
      ],
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "ALERTS{alertstate=\"firing\"}",
          "legendFormat": "",
          "refId": "A",
          "instant": true,
          "format": "table"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "time() - ALERTS_FOR_STATE{alertstate=\"firing\"}",
          "legendFormat": "",
          "refId": "B",
          "instant": true,
          "format": "table"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Firing Alerts Over Time",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10, "gradientMode": "opacity", "spanNulls": false },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "critical" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] },
          { "matcher": { "id": "byName", "options": "warning" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] },
          { "matcher": { "id": "byName", "options": "info" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "count(ALERTS{alertstate=\"firing\"}) by (severity)", "legendFormat": "{{severity}}", "refId": "A" }
      ]
    },
    {
      "id": 7,
      "type": "piechart",
      "title": "By Severity",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "critical" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] },
          { "matcher": { "id": "byName", "options": "warning" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] },
          { "matcher": { "id": "byName", "options": "info" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }] }
        ]
      },
      "options": { "pieType": "donut", "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] }, "tooltip": { "mode": "single" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "count(ALERTS{alertstate=\"firing\"}) by (severity)", "legendFormat": "{{severity}}", "refId": "A", "instant": true }
      ]
    },
    {
      "id": 8,
      "type": "table",
      "title": "Stale Alerts — firing > 24h (most urgent to resolve)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "left", "cellOptions": { "type": "auto" } },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "firing_for" }, "properties": [{ "id": "unit", "value": "s" }, { "id": "custom.width", "value": 160 }, { "id": "displayName", "value": "Firing For" }, { "id": "custom.cellOptions", "value": { "type": "color-background" } }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }, { "color": "red", "value": 604800 }] } }] },
          { "matcher": { "id": "byName", "options": "alertname" }, "properties": [{ "id": "custom.width", "value": 280 }] },
          { "matcher": { "id": "byName", "options": "severity" }, "properties": [{ "id": "custom.width", "value": 100 }] },
          { "matcher": { "id": "byName", "options": "namespace" }, "properties": [{ "id": "custom.width", "value": 160 }] },
          { "matcher": { "id": "byName", "options": "Time" }, "properties": [{ "id": "custom.hidden", "value": true }] },
          { "matcher": { "id": "byName", "options": "Value" }, "properties": [{ "id": "custom.hidden", "value": true }] }
        ]
      },
      "options": {
        "footer": { "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Firing For" }]
      },
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns" } },
        { "id": "organize", "options": { "renameByName": { "Value": "firing_for" } } },
        {
          "id": "filterFieldsByName",
          "options": { "include": { "names": ["alertname", "severity", "namespace", "job", "firing_for"] } }
        }
      ],
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sort_desc(time() - ALERTS_FOR_STATE{alertstate=\"firing\"} > 86400)",
          "legendFormat": "",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ]
    }
  ],
  "schemaVersion": 38,
  "style": "dark",
  "timezone": "browser",
  "version": 1
}
